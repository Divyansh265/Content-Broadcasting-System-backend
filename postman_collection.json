{
  "info": {
    "name": "Content Broadcasting System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://content-broadcasting-system-backend-j8oi.onrender.com" },
    { "key": "teacher_token", "value": "" },
    { "key": "principal_token", "value": "" },
    { "key": "teacher_id", "value": "" },
    { "key": "content_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Teacher",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teacher\",\n  \"email\": \"teacher@school.com\",\n  \"password\": \"password123\",\n  \"role\": \"teacher\"\n}"
            }
          }
        },
        {
          "name": "Register Principal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Principal\",\n  \"email\": \"principal@school.com\",\n  \"password\": \"password123\",\n  \"role\": \"principal\"\n}"
            }
          }
        },
        {
          "name": "Login Teacher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('teacher_token', res.data.token);",
                  "  pm.collectionVariables.set('teacher_id', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login Principal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('principal_token', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@school.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Teacher",
      "item": [
        {
          "name": "Upload Content",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('content_id', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacher_token}}" }],
            "url": "{{base_url}}/content/upload",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Algebra Basics", "type": "text" },
                { "key": "subject", "value": "math", "type": "text" },
                { "key": "description", "value": "Introduction to algebra", "type": "text" },
                { "key": "start_time", "value": "2026-01-01T00:00:00.000Z", "type": "text" },
                { "key": "end_time", "value": "2027-01-01T00:00:00.000Z", "type": "text" },
                { "key": "rotation_duration", "value": "5", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Get My Content (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacher_token}}" }],
            "url": {
              "raw": "{{base_url}}/content/my?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Content By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{teacher_token}}" }],
            "url": "{{base_url}}/content/my/{{content_id}}"
          }
        }
      ]
    },
    {
      "name": "Principal",
      "item": [
        {
          "name": "Get Pending Content (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{principal_token}}" }],
            "url": {
              "raw": "{{base_url}}/content/pending?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Approve Content",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{principal_token}}" }],
            "url": "{{base_url}}/content/{{content_id}}/approve"
          }
        },
        {
          "name": "Reject Content",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{principal_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/content/{{content_id}}/reject",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Image quality is too low\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "Get Live Content",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/content/live/{{teacher_id}}"
          }
        }
      ]
    }
  ]
}
